<?xml version="1.0" encoding="UTF-8"?>
<!--
	Navezgane Hospital Challenge — Blocks
	Author: Frilioth
	Version: 1.2.4
	
-->

<configs>

	<remove xpath="//drop[@name='smallEngine']"/>

	<append xpath="/blocks">

		<block name="posterProstate">
			<property name="TitleKey" value="posterProstateTitle"/>
			<property name="DescriptionKey" value="posterProstateDesc"/>
			<property name="CustomIcon" value="posterProstate"/>
			<property name="CreativeMode" value="Player"/>
			<property name="Material" value="Mpaper"/>
			<property name="StabilitySupport" value="false"/>
			<property name="Shape" value="ModelEntity"/>
			<property name="Model" value="#@modfolder:Resources/hospitalPoster.unity3d?Prostate.prefab"/>
			<property name="Place" value="TowardsPlacerInverted"/>
			<property name="IsDecoration" value="true"/>
			<property name="Stacknumber" value="10" />
			<property name="CanPickup" value="false"/>
			<property name="ImposterDontBlock" value="true"/>
			<drop event="Destroy" count="0"/>
			<property name="FilterTags" value="fdecor,fother"/>
			<property name="SortOrder1" value="7000"/>
			<property name="SortOrder2" value="0002"/>
			<property name="SellableToTrader" value="false"/>
			<property name="Group" value="Decor/Miscellaneous"/>
		</block>
		
		<block name="posterARUK">
			<property name="TitleKey" value="posterARUKTitle"/>
			<property name="DescriptionKey" value="posterARUKDesc"/>
			<property name="CustomIcon" value="ARUK"/>
			<property name="CreativeMode" value="Player"/>
			<property name="Material" value="Mpaper"/>
			<property name="StabilitySupport" value="false"/>
			<property name="Shape" value="ModelEntity"/>
			<property name="Model" value="#@modfolder:Resources/hospitalPoster.unity3d?ARUK.prefab"/>
			<property name="Place" value="TowardsPlacerInverted"/>
			<property name="IsDecoration" value="true"/>
			<property name="Stacknumber" value="10" />
			<property name="CanPickup" value="false"/>
			<property name="ImposterDontBlock" value="true"/>
			<drop event="Destroy" count="0"/>
			<property name="FilterTags" value="fdecor,fother"/>
			<property name="SortOrder1" value="7000"/>
			<property name="SortOrder2" value="0002"/>
			<property name="SellableToTrader" value="false"/>
			<property name="Group" value="Decor/Miscellaneous"/>
		</block>
		
		<block name="posterARUK1">
			<property name="TitleKey" value="posterARUK1Title"/>
			<property name="DescriptionKey" value="posterARUK1Desc"/>
			<property name="CustomIcon" value="ARUK1"/>
			<property name="CreativeMode" value="Player"/>
			<property name="Material" value="Mpaper"/>
			<property name="StabilitySupport" value="false"/>
			<property name="Shape" value="ModelEntity"/>
			<property name="Model" value="#@modfolder:Resources/hospitalPoster.unity3d?ARUK1.prefab"/>
			<property name="Place" value="TowardsPlacerInverted"/>
			<property name="IsDecoration" value="true"/>
			<property name="Stacknumber" value="10" />
			<property name="CanPickup" value="false"/>
			<property name="ImposterDontBlock" value="true"/>
			<drop event="Destroy" count="0"/>
			<property name="FilterTags" value="fdecor,fother"/>
			<property name="SortOrder1" value="7000"/>
			<property name="SortOrder2" value="0002"/>
			<property name="SellableToTrader" value="false"/>
			<property name="Group" value="Decor/Miscellaneous"/>
		</block>


	</append>

<!-- Hospital: potted plants can drop aloe seeds with 10% chance -->

<append xpath="/blocks/block[@name='treePlant02']">
    <drop event="Harvest" name="plantedAloe1" count="1" prob="0.1"/>
    <drop event="Destroy" name="plantedAloe1" count="1" prob="0.1"/>
    <drop event="Harvest" name="resourceYuccaFibers" count="15,20" prob="0.1"/>
    <drop event="Destroy" name="resourceYuccaFibers" count="15,20" prob="0.1"/>
</append>

<!-- Indestructible workstations — prevent player soft-locking -->

<set xpath="/blocks/block[@name='workbench']/property[@name='MaxDamage']/@value">9999</set>
<set xpath="/blocks/block[@name='chemistryStation']/property[@name='MaxDamage']/@value">9999</set>

<!-- IV Stand — always drops a blood bag (needed for Voss-7 Reagent recipe) -->
<set xpath="/blocks/block[@name='standIV']/drop[@name='medicalBloodBag']/@count">1</set>

<!-- Remove sunlight requirement from crops — allows plants to grow indoors -->
<append xpath="//block[@name='cropsGrowingMaster']">
	<property name="PlantGrowing.LightLevelGrow" value="0"/>
	<property name="PlantGrowing.LightLevelStay" value="0"/>
</append>

<!-- Body bags — increased rotten flesh on harvest -->
<!-- All variants extend bodyBagBlack so setting count on parent covers all -->

<set xpath="/blocks/block[@name='bodyBagBlack']/drop[@event='Harvest'][@name='foodRottingFlesh']/@count">4,8</set>

</configs>