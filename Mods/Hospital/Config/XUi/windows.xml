<?xml version="1.0" encoding="UTF-8"?>
<!--
	Hospital Challenge - UI Modifications
	Author: Frilioth
	Version: 2.0.1
	
	MODIFICATIONS:
	- Enlarge ShowMessageWindow (windowTip) for better readability
	- Increase font size for message text
	- Centre-align title and body text
	- Zombie HP bar always visible
	- Push windowEntering (area/storm notifications) down so it doesn't overlap health bar
	- Hide POI name and difficulty skulls from windowEntering
-->
<configs>	
	<!-- Overall window height - makes the entire message window 663 pixels tall -->
	<set xpath="//window[@name='windowTip']/@height">663</set>
	
	<!-- Window position on screen: -300 = 300 pixels left of center, 250 = 250 pixels down from top -->
	<set xpath="//window[@name='windowTip']/@pos">-300,200</set>
	
	<!-- Header panel position (the title bar at top of window) -->
	<setattribute xpath="//window[@name='windowTip']/panel[@name='header']" name="pos">0,190</setattribute>
	
	<!-- Centre-align the title label in the header -->
	<setattribute xpath="//window[@name='windowTip']/panel[@name='header']/label[@style='header.name']" name="justify">center</setattribute>

	<!-- Content area position - where the actual message text starts -->
	<set xpath="//window[@name='windowTip']/rect[@name='content']/@pos">0,146</set>
	
	<!-- Content area height - how tall the scrollable text area is -->
	<set xpath="//window[@name='windowTip']/rect[@name='content']/@height">663</set>
	
	<!-- Text label height - the actual text display area (30px smaller than content for padding) -->
	<set xpath="//window[@name='windowTip']/rect[@name='content']/label[@name='descriptionText']/@height">633</set>
	
	<!-- Font size increase for readability -->
	<setattribute xpath="//window[@name='windowTip']/rect[@name='content']/label[@name='descriptionText']" name="font_size">36</setattribute>

	<!-- Centre-align the body text -->
	<setattribute xpath="//window[@name='windowTip']/rect[@name='content']/label[@name='descriptionText']" name="justify">center</setattribute>
	
	<!-- Continue button position - placed at bottom of window (negative value positions from bottom) -->
	<set xpath="//window[@name='windowTip']/rect[@name='content']/rect[@name='btnContinue']/@pos">0,-663</set>
	
    <!-- Zombie HP bar -->
    <set xpath="/windows/window[@name='windowTargetBar']/@visibility">always</set>

	<!-- Push area/storm notifications down so they don't overlap the health bar -->
	<set xpath="//window[@name='windowEntering']/rect/@pos">-170,-140</set>

	<!-- windowEntering centre popup: keep POI name, remove difficulty skulls only -->
	<remove xpath="//window[@name='windowEntering']/rect/grid"/>

	<!-- windowLocation top-right persistent display: remove entirely -->
	<remove xpath="//window[@name='windowLocation']/label"/>
	<remove xpath="//window[@name='windowLocation']/grid"/>
	<remove xpath="//window[@name='windowLocation']/sprite"/>

    <!-- Congratulations panel — shown in trader window group Center slot when talking to Jen -->
    <!-- This is a standalone window added to the trader window group via xui.xml patch.      -->
    <!-- It only ever appears when the trader UI is open, so no visibility gating needed.     -->
</configs>