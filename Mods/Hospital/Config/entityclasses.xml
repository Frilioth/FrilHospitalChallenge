<?xml version="1.0" encoding="UTF-8"?>
<!--
	Navezgane Hospital Challenge — Entity Classes
	Author: Frilioth
	Version: 0.4.0

	BAG TYPES:
	- HospitalYellow  : medical supplies — Nurse, Lab, Hazmat
	- HospitalCops    : acid + tail assembly — FatCop, Soldier, Mutated
	- HospitalBiker   : spark plugs — Biker, Lumberjack
	- HospitalHeavy   : engine parts — UtilityWorker, Janitor
	- HospitalBooks   : skill mags — generic zombies (Boe, Joe, Marlene, etc.)

	All bag drops via DLL: HospitalBagClass / HospitalBagProb
	No direct inventory drops — all parts via bags or world loot only.
-->
<configs>

	<!-- ============================================================ -->
	<!-- LOOT BAG ENTITY CLASSES                                       -->
	<!-- ============================================================ -->

	<append xpath="/entity_classes">

		<!-- Yellow bag: medical / hospital supplies -->
		<entity_class name="EntityLootContainerHospitalYellow" extends="EntityLootContainerRegular">
			<property name="LootListOnDeath" value="HospitalYellow"/>
			<property name="OverrideName" value="lootHospitalYellow"/>
			<property name="SizeScale" value="0.9"/>
		</entity_class>

		<!-- Books rucksack: skill magazines -->
		<entity_class name="EntityLootContainerHospitalBooks" extends="EntityLootContainerRegular">
			<property name="LootListOnDeath" value="HospitalBooks"/>
			<property name="OverrideName" value="lootHospitalBooks"/>
			<property name="Mesh" value="@:Entities/LootContainers/backpack_vehicleDroppedPrefab.prefab"/>
			<property name="SizeScale" value="0.75"/>
		</entity_class>

		<!-- Cops bag: acid + tail assembly -->
		<entity_class name="EntityLootContainerHospitalCops" extends="EntityLootContainerRegular">
			<property name="LootListOnDeath" value="HospitalCops"/>
			<property name="OverrideName" value="lootHospitalCops"/>
			<property name="SizeScale" value="0.9"/>
		</entity_class>

		<!-- Biker bag: spark plugs -->
		<entity_class name="EntityLootContainerHospitalBiker" extends="EntityLootContainerRegular">
			<property name="LootListOnDeath" value="HospitalBiker"/>
			<property name="OverrideName" value="lootHospitalBiker"/>
			<property name="SizeScale" value="0.85"/>
		</entity_class>

		<!-- Heavy bag: engine parts -->
		<entity_class name="EntityLootContainerHospitalHeavy" extends="EntityLootContainerRegular">
			<property name="LootListOnDeath" value="HospitalHeavy"/>
			<property name="OverrideName" value="lootHospitalHeavy"/>
			<property name="SizeScale" value="0.9"/>
		</entity_class>

	</append>

	<!-- ============================================================ -->
	<!-- YELLOW BAG — Nurse, Lab, Hazmat                              -->
